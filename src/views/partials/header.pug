header
    a(href="/").header__logo
        i.fab.fa-youtube
        span.logo__text  Wetube
    
    nav.header__nav
        ul  
            li.search__wrapper
                a(href="javascript:void(0);").search-toggle
                    i.fas.fa-search
                form.search__form(method="GET", action="/search")
                    input(type="text", name="keyword", placeholder="Search by title")
            if loggedIn
                li
                    a.header__nav-link(href="/videos/upload") Upload A Video
                li 
                    a.header__nav-link(href="/users/edit") Edit Profile
                li 
                    a.header__nav-link(href="/users/logout") Log Out
                li 
                    a(href=`/users/${loggedInUser._id}`)
                        if loggedInUser.avatarUrl === ""
                            span 😊
                        else 
                            img.header_avatar(src=`${loggedInUser.avatarUrl}`)
            else
                li 
                    a.header__nav-link(href="/login") Login
                li 
                    a.header__nav-link(href="/join").header__btn Join